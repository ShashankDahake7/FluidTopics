# MongoDB (must be Atlas — Atlas Search is required)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/fluid_topics

# Atlas Search index names (defined on the `topics` collection in Atlas).
# See backend/ATLAS_SEARCH.md for the index JSON definitions.
ATLAS_SEARCH_INDEX=default
ATLAS_AUTOCOMPLETE_INDEX=autocomplete_title

# JWT
JWT_SECRET=your_production_secret_key
JWT_EXPIRES_IN=7d

# Backend
BACKEND_PORT=4000
NODE_ENV=production

# Frontend
# In Vercel, this should point to your production API URL if not using rewrites, 
# or be left blank if using the provided vercel.json rewrites.
NEXT_PUBLIC_API_URL=/api

# For Vercel rewrites to work with a separate backend (if not using vercel.json)
BACKEND_URL=http://localhost:4000

# Groq AI
GROQ_API_KEY=your_groq_api_key
