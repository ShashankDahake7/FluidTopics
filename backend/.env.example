# MongoDB
MONGODB_URI=

# Elasticsearch
ELASTICSEARCH_URL=
ELASTICSEARCH_INDEX=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=

# Darwinbox Help Portal SSO
# Configure Darwinbox to redirect to:
#   https://<api-or-app-host>/api/auth/sso/darwinbox/handoff?sp=help_portal&data=<encrypted>
DARWINBOX_HELP_PORTAL_SSO_ENCRYPTION_KEY=
# Optional 16-byte AES-CBC IV. Accepts utf8, hex (32 chars), or base64.
# Leave blank only if Darwinbox uses an all-zero IV.
DARWINBOX_HELP_PORTAL_SSO_IV=
DARWINBOX_HELP_PORTAL_POST_SSO_REDIRECT_BASE=https://help.darwinbox.com
DARWINBOX_HELP_PORTAL_SSO_DEBUG=false

# Backend
BACKEND_PORT=
NODE_ENV=

# Frontend
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_DARWINBOX_CLIENT_SSO_URL=https://help.darwinbox.com/api/authentication/sso/darwinbox-clients-sso-prod/login?urlAfterLogin=https%3A%2F%2Fhelp.darwinbox.com%2Fhome&Ft-Calling-App=ft%2Fturnkey-portal&Ft-Calling-App-Version=5.3.3
NEXT_PUBLIC_DARWINBOX_EMPLOYEE_SSO_URL=https://help.darwinbox.com/api/authentication/sso/Darwinbox_fluidtopics/login?urlAfterLogin=https%3A%2F%2Fhelp.darwinbox.com%2Fhome&Ft-Calling-App=ft%2Fturnkey-portal&Ft-Calling-App-Version=5.3.3
NEXT_PUBLIC_DARWINBOX_STAGING_SSO_URL=https://help.darwinbox.com/api/authentication/sso/sso-stage-realm/login?urlAfterLogin=https%3A%2F%2Fhelp.darwinbox.com%2Fhome&Ft-Calling-App=ft%2Fturnkey-portal&Ft-Calling-App-Version=5.3.3

# File Storage
UPLOAD_DIR=
# 500 MB cap (matches frontend/next.config.mjs middlewareClientMaxBodySize).
# Multer rejects anything larger; bump on both sides if your zips exceed this.
MAX_FILE_SIZE=
# Groq AI (Phase 3)
GROQ_API_KEY=

# ── AWS / S3 (Publishing pipeline) ──────────────────────────────────────────
# Both buckets are required and live in the same region/account. Raw bucket
# holds the uploaded .zip exactly as received; extracted bucket holds the
# per-file unpacked contents under the same publication-id prefix (1:1
# mapping). For local dev you can point these at MinIO/LocalStack by setting
# S3_ENDPOINT + S3_FORCE_PATH_STYLE=true.
# AWS credentials — read by the AWS SDK directly; also accepted by our
# config/env.js loader. Use IAM access keys scoped to s3:* on these buckets.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Bucket names. S3_UPLOAD_BUCKET is an accepted alias for S3_RAW_BUCKET.
S3_UPLOAD_BUCKET=
S3_EXTRACTED_BUCKET=

# Optional overrides — leave unset for real AWS S3.
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=

# Presigned URL TTL in seconds (used by Download archive / file links).
S3_PRESIGN_EXPIRES=

# Max object size we'll extract from a single zip entry (bytes). Guard against
# zip-bomb entries; default 1 GiB.
PUBLISH_MAX_ENTRY_BYTES=

# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USER=ab8bf15eadbd81
# SMTP_PASS=ce211132a13754
# SMTP_FROM=use.as.prof.01@gmail.com

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ===== Paligo API credentials =====
 
PALIGO_INSTANCE=
PALIGO_BASE_URL=
PALIGO_USERNAME=
PALIGO_TOKEN=
# PALIGO_API_KEY is also accepted as an alias for PALIGO_TOKEN.
PALIGO_API_KEY=