{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/backend/api/:path*"
        },
        {
            "source": "/uploads/:path*",
            "destination": "/backend/uploads/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/$1"
        }
    ],
    "builds": [
        {
            "src": "backend/src/index.js",
            "use": "@vercel/node"
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/next"
        }
    ]
}